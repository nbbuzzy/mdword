{
  "name": "mdword",
  "version": "0.1.4",
  "description": "Bidirectional markdown ↔ Word conversion with mermaid diagram support",
  "type": "module",
  "bin": {
    "mdword": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "templates/default-reference.docx",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "md2word": "tsx src/cli.ts md2word",
    "word2md": "tsx src/cli.ts word2md"
  },
  "keywords": [
    "markdown",
    "docx",
    "word",
    "conversion",
    "converter",
    "mermaid",
    "diagrams",
    "pandoc",
    "cli",
    "round-trip",
    "bidirectional",
    "markdown-to-word",
    "word-to-markdown"
  ],
  "author": "nbbuzzy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nbbuzzy/mdword.git"
  },
  "homepage": "https://github.com/nbbuzzy/mdword#readme",
  "bugs": {
    "url": "https://github.com/nbbuzzy/mdword/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^1.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
